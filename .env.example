# Plantilla de variables de entorno (DEVOPS-02, auditoria 17-jul-2026).
# Copiar los valores reales a ~/.bashrc (o al gestor de secretos que se use
# en produccion) -- este archivo NUNCA debe llevar valores reales, solo
# placeholders. Es seguro de commitear tal cual.

# --- Base de datos MySQL (docker-compose.yml + application.yml) ---
# Usuario de la app (no root). Default si se omite: textil_user
DB_USERNAME=textil_user
# Password del usuario de la app (textil_user). SIN valor por defecto a
# proposito -- la app no arranca sin esto (ver seguridad: la password fue
# rotada y sacada del repo con git filter-repo el 15-jul-2026, nunca debe
# volver a commitearse).
DB_PASSWORD=
# Password de root de MySQL, USADA SOLO por docker-compose y por los scripts
# de backup/restore -- nunca por la app. Debe ser DISTINTA de DB_PASSWORD: si
# se filtra la credencial de la app, no debe dar acceso root a la base de datos.
MYSQL_ROOT_PASSWORD=

# --- IA / OCR (AnthropicOcrService) ---
# API key de Anthropic para el OCR de guias/facturas. Sin este valor el
# OCR simplemente no funciona (no rompe el resto de la app).
ANTHROPIC_API_KEY=

# --- Almacenamiento de documentos ---
# Carpeta donde se guardan los PDFs de guias/facturas/Archivo Historico.
# Default si se omite: ./documentos (relativo al directorio de trabajo)
DOCUMENTOS_PATH=./documentos

# --- Limites de subida (SEC-09, auditoria anterior) ---
# Tamano maximo por archivo Y por request completo. Default: 25MB
MAX_UPLOAD_SIZE=25MB

# --- Marca (layout/base.html) ---
# Nombre del negocio que aparece bajo el logo TEXCONTROL en el sidebar.
# TEXCONTROL es el nombre del producto y no cambia; esto es lo que
# distingue a cada cliente/instalacion cuando se despliega el mismo
# codigo para otro negocio. Default si se omite: "Laura & Clemente"
NOMBRE_EMPRESA=Laura & Clemente

# --- Sesion "recordar" en el celular (SecurityConfig, remember-me) ---
# Clave secreta que firma la cookie persistente que mantiene logueado al
# usuario en la PWA movil aunque el celular suspenda la app o caduque la
# sesion. DEBE ser un valor unico y secreto por instancia, y NO cambiar entre
# despliegues: si cambia, todas las cookies se invalidan y los usuarios
# quedan deslogueados. Generar por ejemplo con: openssl rand -hex 32
# Si se omite, se usa un default de desarrollo (no usar en produccion).
REMEMBER_ME_KEY=

# --- Exposicion de red (docker-compose.prod.yml, solo produccion) ---
# IP a la que se publican los puertos 80/443 de nginx. Hoy el VPS sirve la app
# publicamente por dominio (texcontrol.pe) con HTTPS, asi que va BIND_IP=0.0.0.0
# (todas las interfaces; el TLS lo termina nginx). Si algun dia quisieras
# exponerla solo por una interfaz o VPN interna, fija aca esa IP. Sin valor,
# Docker cae por defecto en 0.0.0.0.
BIND_IP=0.0.0.0
