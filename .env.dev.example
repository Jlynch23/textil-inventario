# Entorno de PRUEBAS (staging) — variables del stack docker-compose.dev.yml.
# Copiar a .env.dev EN EL VPS (dentro del clon dev) y completar. NUNCA se
# versiona (esta en .gitignore). La BD es PROPIA del entorno dev, separada de
# produccion. Usar claves HEX (sin simbolos): openssl rand -hex 24 / -hex 32.

DB_USERNAME=textil_user
# openssl rand -hex 24
DB_PASSWORD=
# openssl rand -hex 24 (DISTINTA de DB_PASSWORD)
MYSQL_ROOT_PASSWORD=
# Opcional: sin esto el OCR no anda en dev, pero la app arranca igual.
ANTHROPIC_API_KEY=
MAX_UPLOAD_SIZE=25MB
# Marca visible para distinguir dev de produccion.
NOMBRE_EMPRESA=DEV - Pruebas
# OBLIGATORIA (la app no arranca si falta). Generar con: openssl rand -hex 32
REMEMBER_ME_KEY=
